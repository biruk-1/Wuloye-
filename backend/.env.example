# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Firebase Admin SDK ──────────────────────────────────────────────────────
# All values come from the Firebase project's service account JSON file.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g. http://localhost:3000,https://app.wuloye.com)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ─── Google Maps (Phase 14 — optional) ───────────────────────────────────────
# When set, GET /api/recommendations?lat=<lat>&lng=<lng>&radius=<km> will fetch
# real nearby places from the Google Maps Places API (Nearby Search) instead of
# the static Firestore catalogue.
# Required APIs: Places API (legacy) — enable at https://console.cloud.google.com/apis
# Leave blank to use Firestore data only (graceful fallback).
GOOGLE_MAPS_API_KEY=

# ─── Phase 15 — Performance (optional) ───────────────────────────────────────
# Recommendation result cache TTL (ms). Default 300000 = 5 minutes.
# RECOMMENDATION_CACHE_TTL_MS=300000
# Auto fast mode when concurrent /recommendations exceeds this count (in-process).
# RECOMMENDATION_HIGH_LOAD_CONCURRENT=8
# Force fast mode (skip embedding + model): RECOMMENDATIONS_HIGH_LOAD=true
# Places scored per setImmediate chunk for parallel scheduling.
# RECOMMENDATION_SCORE_CHUNK_SIZE=8
# Redis: not wired — use in-memory TtlCache; add ioredis + shared store for multi-instance.
